# Copy to .env.local for local testing (never commit real secrets).
# In Vercel: Project → Settings → Environment Variables → CMS_WRITE_SECRET

# Required on Vercel for POST/PATCH/PUT/DELETE on /api/articles and POST /api/upload-image.
# Use a long random string; paste the same value into admin.html "API key" on the live site.
CMS_WRITE_SECRET=

# Vercel /api/upload-image: use Cloudflare R2 (S3 API) when Blob is unavailable.
# Create an R2 API token (R2 → Manage R2 API Tokens) with read+write on the bucket.
# R2_ACCOUNT_ID = Cloudflare Dashboard URL account id (same as wrangler account id).
# CMS_UPLOAD_PUBLIC_BASE = R2 bucket public dev URL or custom domain (no trailing slash).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=seedance-2-upload
CMS_UPLOAD_PUBLIC_BASE=
