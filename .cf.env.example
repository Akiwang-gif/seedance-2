# 复制为 .cf.env 并填入真实值（.cf.env 已 gitignore）
# Token：https://dash.cloudflare.com/profile/api-tokens
# 建议权限：Account → Cloudflare Pages → Edit；Account → Account Settings → Read
CLOUDFLARE_API_TOKEN=
# 在 Cloudflare 控制台右侧边栏「Account ID」（可选，多数情况下 wrangler 能自动解析）
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Pages Functions 代理 /api/* 时的上游（必须是“真实后端”，不要填当前站点自身域名，否则会回环）
# 例：https://seedance-2-xxxx.vercel.app
API_PROXY_ORIGIN=

# 阶段 2 数据同步脚本需要：Cloudflare KV namespace ID（不是 binding 名称）
CMS_KV_NAMESPACE_ID=
# 可选：同步时拉取草稿+已发布（/api/articles?scope=all）
CMS_BEARER_TOKEN=
