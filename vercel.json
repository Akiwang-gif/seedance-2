{
  "framework": null,
  "buildCommand": "echo 'Static + API'",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "seedance-2.info" }],
      "destination": "https://www.seedance-2.info/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/article/:id", "destination": "/api/article-page?id=:id" }
  ]
}
